#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
encryption_keys.key - Encryption Key Management
WARNING: DO NOT SHARE THIS FILE!
"""

import base64
import json
from datetime import datetime, timedelta
from cryptography.hazmat.primitives import serialization
from cryptography.hazmat.primitives.asymmetric import rsa
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
import os

class EncryptionKeys:
    """Manages encryption keys for the framework"""
    
    def __init__(self, key_file="encryption_keys.key"):
        self.key_file = key_file
        self.keys = {}
        self.load_keys()
    
    def generate_aes_key(self, key_size=32):
        """Generate a new AES key"""
        return os.urandom(key_size)
    
    def generate_rsa_keys(self, key_size=2048):
        """Generate RSA key pair"""
        private_key = rsa.generate_private_key(
            public_exponent=65537,
            key_size=key_size
        )
        public_key = private_key.public_key()
        
        # Serialize keys
        private_pem = private_key.private_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PrivateFormat.PKCS8,
            encryption_algorithm=serialization.NoEncryption()
        )
        
        public_pem = public_key.public_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PublicFormat.SubjectPublicKeyInfo
        )
        
        return {
            'private': private_pem.decode('utf-8'),
            'public': public_pem.decode('utf-8')
        }
    
    def derive_key_from_password(self, password, salt=None):
        """Derive encryption key from password"""
        if salt is None:
            salt = os.urandom(16)
        
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA256(),
            length=32,
            salt=salt,
            iterations=100000,
        )
        
        key = kdf.derive(password.encode())
        return key, salt
    
    def create_default_keys(self):
        """Create default encryption keys"""
        print("🔐 Generating encryption keys...")
        
        # AES-256 Master Key
        self.keys['aes_master'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'expires': (datetime.now() + timedelta(days=90)).isoformat(),
            'algorithm': 'AES-256-GCM',
            'purpose': 'Master encryption for all sensitive data'
        }
        
        # RSA Key Pair for asymmetric encryption
        rsa_keys = self.generate_rsa_keys(2048)
        self.keys['rsa_keys'] = {
            'private': rsa_keys['private'],
            'public': rsa_keys['public'],
            'created': datetime.now().isoformat(),
            'algorithm': 'RSA-2048',
            'purpose': 'Asymmetric encryption and digital signatures'
        }
        
        # File Encryption Key
        self.keys['file_encryption'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'AES-256-CBC',
            'purpose': 'File and directory encryption'
        }
        
        # Communication Encryption Key
        self.keys['comms_key'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'ChaCha20-Poly1305',
            'purpose': 'Secure communication between modules'
        }
        
        # Database Encryption Key
        self.keys['db_key'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'AES-256-GCM',
            'purpose': 'Database encryption'
        }
        
        # Backup Master Key
        self.keys['backup_master'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'AES-256-GCM',
            'purpose': 'Backup file encryption'
        }
        
        # Webcam/Media Encryption Key
        self.keys['media_key'] = {
            'key': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'AES-256-CTR',
            'purpose': 'Media file encryption (images, videos)'
        }
        
        # Password-derived key (for user authentication)
        password = "ChangeThisDefaultPassword123!"
        derived_key, salt = self.derive_key_from_password(password)
        self.keys['password_key'] = {
            'key': base64.b64encode(derived_key).decode('utf-8'),
            'salt': base64.b64encode(salt).decode('utf-8'),
            'created': datetime.now().isoformat(),
            'algorithm': 'PBKDF2-SHA256',
            'purpose': 'Password-based key derivation'
        }
        
        # Session Keys (for temporary operations)
        self.keys['session_keys'] = {
            'current': base64.b64encode(self.generate_aes_key(32)).decode('utf-8'),
            'previous': '',
            'created': datetime.now().isoformat(),
            'lifetime': 3600,  # 1 hour
            'purpose': 'Temporary session encryption'
        }
        
        # Metadata
        self.keys['_metadata'] = {
            'version': '1.0.0',
            'created': datetime.now().isoformat(),
            'last_modified': datetime.now().isoformat(),
            'key_count': len(self.keys) - 1,  # Exclude metadata
            'warning': 'DO NOT SHARE THIS FILE! Contains sensitive encryption keys.',
            'backup_location': 'secure_backup_location.key',
            'rotation_schedule': '90 days'
        }
        
        self.save_keys()
        print(f"✅ Generated {len(self.keys) - 1} encryption keys")
    
    def save_keys(self):
        """Save keys to encrypted file"""
        try:
            # In production, encrypt this file with a master password
            with open(self.key_file, 'w') as f:
                json.dump(self.keys, f, indent=2)
            
            # Set restrictive permissions (Unix)
            if os.name != 'nt':
                os.chmod(self.key_file, 0o600)
            
            self.keys['_metadata']['last_modified'] = datetime.now().isoformat()
            print(f"💾 Keys saved to {self.key_file}")
        except Exception as e:
            print(f"❌ Error saving keys: {e}")
    
    def load_keys(self):
        """Load keys from file"""
        try:
            if os.path.exists(self.key_file):
                with open(self.key_file, 'r') as f:
                    self.keys = json.load(f)
                print(f"📂 Loaded keys from {self.key_file}")
            else:
                print("⚠️  Key file not found, creating default keys...")
                self.create_default_keys()
        except Exception as e:
            print(f"❌ Error loading keys: {e}")
            self.create_default_keys()
    
    def get_key(self, key_name):
        """Get a specific key"""
        if key_name in self.keys:
            key_data = self.keys[key_name]
            if 'key' in key_data:
                return base64.b64decode(key_data['key'])
        return None
    
    def rotate_keys(self):
        """Rotate encryption keys"""
        print("🔄 Rotating encryption keys...")
        
        # Keep old session key
        if 'session_keys' in self.keys:
            self.keys['session_keys']['previous'] = self.keys['session_keys']['current']
            self.keys['session_keys']['current'] = base64.b64encode(
                self.generate_aes_key(32)
            ).decode('utf-8')
            self.keys['session_keys']['created'] = datetime.now().isoformat()
        
        # Update metadata
        self.keys['_metadata']['last_modified'] = datetime.now().isoformat()
        self.keys['_metadata']['key_count'] = len(self.keys) - 1
        
        self.save_keys()
        print("✅ Keys rotated successfully")
    
    def export_public_keys(self, output_file="public_keys.json"):
        """Export only public keys for sharing"""
        public_keys = {}
        
        if 'rsa_keys' in self.keys:
            public_keys['rsa_public'] = self.keys['rsa_keys']['public']
        
        # Add other non-sensitive key information
        public_keys['metadata'] = {
            'version': self.keys.get('_metadata', {}).get('version', '1.0.0'),
            'key_count': self.keys.get('_metadata', {}).get('key_count', 0),
            'last_modified': datetime.now().isoformat()
        }
        
        with open(output_file, 'w') as f:
            json.dump(public_keys, f, indent=2)
        
        print(f"📤 Public keys exported to {output_file}")
        return public_keys
    
    def validate_keys(self):
        """Validate all keys are present and valid"""
        required_keys = [
            'aes_master', 'rsa_keys', 'file_encryption',
            'comms_key', 'db_key', 'backup_master'
        ]
        
        missing = []
        for key in required_keys:
            if key not in self.keys:
                missing.append(key)
        
        if missing:
            print(f"⚠️  Missing required keys: {missing}")
            return False
        
        # Check expiration
        now = datetime.now()
        for key_name, key_data in self.items():
            if 'expires' in key_data:
                expires = datetime.fromisoformat(key_data['expires'])
                if expires < now:
                    print(f"⚠️  Key '{key_name}' has expired!")
                    return False
        
        print("✅ All encryption keys are valid")
        return True
    
    def __getitem__(self, key):
        return self.keys.get(key)
    
    def __setitem__(self, key, value):
        self.keys[key] = value
        self.save_keys()
    
    def items(self):
        return self.keys.items()
    
    def keys(self):
        return self.keys.keys()

# Singleton instance
encryption_keys = EncryptionKeys()

if __name__ == "__main__":
    # Test the encryption keys
    print("🔐 ENCRYPTION KEYS MANAGEMENT")
    print("=" * 50)
    
    # Display key information
    print(f"Total keys: {len(encryption_keys.keys) - 1}")
    
    for key_name, key_data in encryption_keys.items():
        if not key_name.startswith('_'):
            print(f"\n📋 {key_name}:")
            for k, v in key_data.items():
                if k == 'key' and len(str(v)) > 50:
                    print(f"  {k}: {str(v)[:50]}...")
                else:
                    print(f"  {k}: {v}")
    
    # Export public keys
    encryption_keys.export_public_keys()
    
    print("\n" + "=" * 50)
    print("⚠️  WARNING: Keep this file secure!")
    print("💀 Never commit to version control!")
